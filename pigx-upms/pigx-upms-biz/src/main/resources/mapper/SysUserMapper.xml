<?xml version="1.0" encoding="UTF-8"?>

<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.pig4cloud.pigx.admin.mapper.SysUserMapper">
    <!-- 通用查询映射结果 -->
    <resultMap id="baseResultMap" type="com.pig4cloud.pigx.admin.api.vo.UserVO">
        <id column="user_id" property="userId"/>
        <result column="username" property="username"/>
        <result column="password" property="password"/>
        <result column="salt" property="salt"/>
        <result column="phone" property="phone"/>
        <result column="avatar" property="avatar"/>
        <result column="nickname" property="nickname"/>
        <result column="name" property="name"/>
        <result column="email" property="email"/>
        <result column="wx_openid" property="wxOpenid"/>
        <result column="qq_openid" property="qqOpenid"/>
        <result column="gitee_login" property="giteeOpenId"/>
        <result column="osc_id" property="oscOpenId"/>
        <result column="wx_cp_userid" property="wxCpUserid"/>
        <result column="wx_ding_userid" property="wxDingUserid"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
        <result column="lock_flag" property="lockFlag"/>
        <result column="password_expire_flag" property="passwordExpireFlag"/>
        <result column="password_modify_time" property="passwordModifyTime"/>
        <result column="del_flag" property="delFlag"/>
        <collection property="deptList" ofType="com.pig4cloud.pigx.admin.api.entity.SysDept"
                    select="com.pig4cloud.pigx.admin.mapper.SysDeptMapper.listDeptsByUserId"
                    column="{userId=user_id, tenantId=tenant_id}">
        </collection>
        <collection property="roleList" ofType="com.pig4cloud.pigx.admin.api.entity.SysRole"
                    select="com.pig4cloud.pigx.admin.mapper.SysRoleMapper.listRolesByUserId"
                    column="{userId=user_id, tenantId=tenant_id}">
        </collection>
        <collection property="postList" ofType="com.pig4cloud.pigx.admin.api.entity.SysPost"
                    select="com.pig4cloud.pigx.admin.mapper.SysPostMapper.listPostsByUserId"
                    column="{userId=user_id, tenantId=tenant_id}">
        </collection>
    </resultMap>

    <sql id="userColumns">
        u.user_id,
        u.username,
        u.password,
        u.salt,
        u.phone,
        u.avatar,
        u.name,
        u.nickname,
        u.email,
        u.wx_openid,
        u.qq_openid,
        u.gitee_login,
        u.osc_id,
        u.wx_cp_userid,
        u.wx_ding_userid,
        u.del_flag,
        u.lock_flag,
        u.password_expire_flag,
        u.password_modify_time,
        u.tenant_id,
        u.create_by,
        u.create_time,
        u.update_time
    </sql>

    <select id="getUserVoByUsername" resultMap="baseResultMap">
        SELECT
        <include refid="userColumns"/>
        FROM
        sys_user u
        WHERE u.username = #{username}  and u.del_flag = '0'
    </select>

    <select id="getUserVoById" resultMap="baseResultMap">
        SELECT
        <include refid="userColumns"/>
        FROM
        sys_user u
        WHERE
        u.user_id = #{id} and u.del_flag = '0'
    </select>

    <select id="getUserVosPage" resultMap="baseResultMap">
        SELECT
        <include refid="userColumns"/>
        FROM
        sys_user u
        INNER JOIN sys_user_dept ud ON u.user_id = ud.user_id
        WHERE
        ud.tenant_id = #{query.tenantId}
        AND u.del_flag = '0'
        <!-- 用户名模糊查询 -->
            <if test="query.username != null and query.username != ''">
                <bind name="usernameLike" value="'%' + query.username + '%'"/>
                AND u.username LIKE #{usernameLike}
            </if>
        <!-- 部门精确查询 -->
            <if test="query.deptId != null and query.deptId != ''">
                AND ud.dept_id = #{query.deptId}
            </if>
        <!-- 手机号模糊查询 -->
            <if test="query.phone != null and query.phone != ''">
                <bind name="phoneLike" value="'%' + query.phone + '%'"/>
                AND u.phone LIKE #{phoneLike}
            </if>
        ORDER BY
        u.create_time DESC
    </select>

    <select id="selectVoListByScope" resultMap="baseResultMap">
        SELECT
        <include refid="userColumns"/>
        FROM
        sys_user u
        INNER JOIN sys_user_dept ud ON u.user_id = ud.user_id
        WHERE
        ud.tenant_id = #{query.tenantId}
        AND u.del_flag = '0'
        <!-- 用户名模糊查询 -->
            <if test="query.username != null and query.username != ''">
                <bind name="usernameLike" value="'%' + query.username + '%'"/>
                AND u.username LIKE #{usernameLike}
            </if>
        <!-- 部门精确查询 -->
            <if test="query.deptId != null and query.deptId != ''">
                AND ud.dept_id = #{query.deptId}
            </if>
        <!-- 用户ID范围查询 -->
            <if test="ids != null and ids.length > 0">
                AND u.user_id IN
                <foreach collection="ids" item="id" open="(" separator="," close=")">
                    #{id}
                </foreach>
            </if>
        ORDER BY
        u.create_time DESC
    </select>
</mapper>
